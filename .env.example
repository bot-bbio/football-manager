# Copy to .env and fill in. .env is gitignored.

# Required: your Anthropic API key (powers the agent).
ANTHROPIC_API_KEY=sk-ant-...

# Required: your Sleeper username (public).
SLEEPER_USERNAME=your_sleeper_username

# Optional: pin a specific league. If omitted and you have exactly one NFL
# league this season, it is auto-detected. Run `fantasy-assistant leagues`
# to list your league ids.
# SLEEPER_LEAGUE_ID=123456789012345678

# Optional: season to use (defaults to the current NFL season).
# SLEEPER_SEASON=2025

# Optional: override the model or reasoning effort.
# FANTASY_ASSISTANT_MODEL=claude-opus-4-8
# FANTASY_ASSISTANT_EFFORT=high
